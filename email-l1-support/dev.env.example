# Secrets template. Copy to ~/dev.env (or ./dev.env) and fill in real keys.
# Do not commit the real file.

# OpenAI (used for the LLM and embeddings)
OPENAI_API_KEY=sk-your-openai-key-here

# SerpAPI (optional, only needed for the web comparison step)
SERPAPI_API_KEY=your-serpapi-key-here

# Guardrails Hub (optional — run: guardrails configure)
# GUARDRAILS_API_KEY=your-guardrails-hub-key-here
